{
  "_comment": "Production workflow: SDXL base 1.0 + Pixel Art XL LoRA. No IP-Adapter (smoke test confirmed LoRA-only produces clean pixel art that matches the prompt directly). Generates at 1024x1024; gen-batch.mjs runs the result through post-process.mjs which Nearest-Neighbor downscales to target resolution. Placeholders {{KEY}} substituted by gen-batch.mjs at runtime.",
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "cfg": 7.5,
      "denoise": 1.0,
      "latent_image": ["5", 0],
      "model": ["10", 0],
      "negative": ["7", 0],
      "positive": ["6", 0],
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "seed": "{{SEED}}",
      "steps": 28
    }
  },
  "4": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "sd_xl_base_1.0.safetensors" }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": { "batch_size": "{{BATCH_SIZE}}", "height": "{{BASE_H}}", "width": "{{BASE_W}}" }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "clip": ["10", 1], "text": "{{PROMPT}}" }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": { "clip": ["10", 1], "text": "{{NEGATIVE}}" }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["3", 0], "vae": ["4", 2] }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": { "filename_prefix": "{{FILENAME_PREFIX}}", "images": ["8", 0] }
  },
  "10": {
    "class_type": "LoraLoader",
    "inputs": {
      "clip": ["4", 1],
      "lora_name": "pixel-art-xl.safetensors",
      "model": ["4", 0],
      "strength_clip": 1.0,
      "strength_model": 1.0
    }
  }
}
